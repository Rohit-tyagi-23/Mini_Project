# ========================================
# Restaurant AI - ENVIRONMENT CONFIGURATION
# ========================================
# Copy this to .env and customize for your environment
# DO NOT commit .env to version control
# ========================================

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# CRITICAL: Must be changed for production
SECRET_KEY=dev-secret-key-change-in-production

# Application Server
APP_HOST=0.0.0.0
APP_PORT=5000

# ========== DATABASE ==========
# SQLite (Development - default)
DATABASE_URL=sqlite:///restaurant_ai.db

# PostgreSQL (Production - uncomment to use)
# DATABASE_URL=postgresql://username:password@localhost:5432/restaurant_ai_db

# ========== REDIS CACHE ==========
# Optional but recommended for production
REDIS_URL=redis://localhost:6379/0

# ========== EMAIL CONFIGURATION ==========
# Gmail example - get app password from myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@restaurantai.com

# ========== SMS CONFIGURATION (TWILIO) ==========
# Optional: For SMS alerts and phone authentication
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ========== CACHE CONFIGURATION ==========
# TTL for forecast cache in hours
FORECAST_CACHE_TTL=24

# ========== OPTIONAL: OAUTH PROVIDERS ==========
# For future OAuth implementation
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ========== PRODUCTION SETTINGS ==========
# Uncomment for production deployments
# FLASK_ENV=production
# GUNICORN_WORKERS=4  
# LOG_LEVEL=info
# RATELIMIT_ENABLED=True

